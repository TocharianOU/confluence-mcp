# Confluence MCP Server – Environment Variables
# Copy to .env for local development

# ── Connection ────────────────────────────────────────────────────────────────
# Confluence Cloud: https://yourorg.atlassian.net
# Confluence Server/DC: https://confluence.yourcompany.com
CONFLUENCE_HOST=https://yourorg.atlassian.net

# ── Authentication ────────────────────────────────────────────────────────────
# Confluence Cloud: Atlassian account email + API token
#   API token: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_EMAIL=your.email@company.com
CONFLUENCE_TOKEN=your_api_token_here

# Confluence Server / Data Center: Personal Access Token (leave CONFLUENCE_EMAIL empty)
# CONFLUENCE_TOKEN=your_personal_access_token_here

# ── API Version ───────────────────────────────────────────────────────────────
# v2 = Confluence Cloud modern API (default)
# v1 = Confluence Server / Data Center (or older Cloud API)
CONFLUENCE_API_VERSION=v2

# ── TLS ───────────────────────────────────────────────────────────────────────
# true = verify SSL certificate (default)
# false = skip SSL verification (self-signed certs)
CONFLUENCE_VERIFY_SSL=true

# ── Timeouts & Limits ─────────────────────────────────────────────────────────
CONFLUENCE_TIMEOUT=30000
MAX_TOKEN_CALL=20000

# ── Transport ─────────────────────────────────────────────────────────────────
# stdio (default) | http
MCP_TRANSPORT=stdio
MCP_HTTP_PORT=3010
